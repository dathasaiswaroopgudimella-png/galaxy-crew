# ============================================================
# PHSE Project — Galaxy Crew
# Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# --- AI / LLM APIs (OPTIONAL — pipeline runs without these) ---
OPENAI_API_KEY=your_openai_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# --- Geocoding & Maps (OPTIONAL) ---
OPENCAGE_API_KEY=your_opencage_key_here
GEOAPIFY_API_KEY=your_geoapify_key_here
IPINFO_API_KEY=your_ipinfo_key_here
WEATHER_API_KEY=your_weather_key_here

# --- PHSE Pipeline Config ---
PHSE_LOG_LEVEL=INFO
PHSE_OUTPUT_DIR=outputs
PHSE_CACHE_DIR=.cache

# --- API Server (FastAPI) ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Gemini API (OPTIONAL) ---
GEMINI_API_KEY=your_gemini_key_here
